{
  "name": "vardionix-vscode",
  "displayName": "Vardionix - DevSecOps",
  "description": "Unified DevSecOps tool for scanning, triaging, and remediating security findings with Semgrep, Claude, and Codex",
  "version": "0.1.8",
  "publisher": "vardionix",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/vovanphuc/vardionix"
  },
  "pricing": "Free",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "security",
    "semgrep",
    "devsecops",
    "vulnerability",
    "scanner",
    "sast",
    "owasp"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vardionix.scanCurrentFile",
        "title": "Scan Current File",
        "category": "Vardionix",
        "icon": "$(shield)"
      },
      {
        "command": "vardionix.scanStagedFiles",
        "title": "Scan Staged Files",
        "category": "Vardionix",
        "icon": "$(git-commit)"
      },
      {
        "command": "vardionix.scanWorkspace",
        "title": "Scan Workspace",
        "category": "Vardionix",
        "icon": "$(folder)"
      },
      {
        "command": "vardionix.listFindings",
        "title": "List Findings",
        "category": "Vardionix",
        "icon": "$(list-unordered)"
      },
      {
        "command": "vardionix.listExcludedFindings",
        "title": "List Excluded Findings",
        "category": "Vardionix",
        "icon": "$(filter)"
      },
      {
        "command": "vardionix.explainFinding",
        "title": "Explain Finding",
        "category": "Vardionix",
        "icon": "$(lightbulb)"
      },
      {
        "command": "vardionix.dismissFinding",
        "title": "Dismiss Finding",
        "category": "Vardionix",
        "icon": "$(close)"
      },
      {
        "command": "vardionix.showPolicy",
        "title": "Show Policy",
        "category": "Vardionix",
        "icon": "$(law)"
      },
      {
        "command": "vardionix.refreshFindings",
        "title": "Refresh Findings",
        "category": "Vardionix",
        "icon": "$(refresh)"
      },
      {
        "command": "vardionix.focusCurrentFile",
        "title": "Toggle Focus Current File",
        "category": "Vardionix",
        "icon": "$(target)"
      },
      {
        "command": "vardionix.configureFindingsView",
        "title": "Configure Findings View",
        "category": "Vardionix",
        "icon": "$(filter)"
      },
      {
        "command": "vardionix.rescanFindingFile",
        "title": "Rescan This File",
        "category": "Vardionix",
        "icon": "$(sync)"
      },
      {
        "command": "vardionix.installMcpIntegration",
        "title": "Install MCP",
        "category": "Vardionix",
        "icon": "$(plug)"
      },
      {
        "command": "vardionix.verifyMcpIntegration",
        "title": "Verify MCP",
        "category": "Vardionix",
        "icon": "$(pass)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vardionix",
          "title": "Vardionix",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "vardionix": [
        {
          "id": "vardionixFindings",
          "name": "Security Findings",
          "type": "tree"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "vardionixFindings",
        "contents": "No security findings yet.\n\nRun a scan to get started.\n[Scan Current File](command:vardionix.scanCurrentFile)\n[Scan Workspace](command:vardionix.scanWorkspace)\n[Scan Staged Files](command:vardionix.scanStagedFiles)\n\nAI agent setup:\n[Install MCP for Claude/Codex](command:vardionix.installMcpIntegration)\n[Verify MCP Setup](command:vardionix.verifyMcpIntegration)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "vardionix.scanCurrentFile",
          "group": "navigation",
          "when": "editorIsOpen"
        }
      ],
      "view/title": [
        {
          "command": "vardionix.scanWorkspace",
          "when": "view == vardionixFindings",
          "group": "navigation@1"
        },
        {
          "command": "vardionix.scanStagedFiles",
          "when": "view == vardionixFindings",
          "group": "navigation@2"
        },
        {
          "command": "vardionix.refreshFindings",
          "when": "view == vardionixFindings",
          "group": "navigation@3"
        },
        {
          "command": "vardionix.focusCurrentFile",
          "when": "view == vardionixFindings",
          "group": "navigation@4"
        },
        {
          "command": "vardionix.configureFindingsView",
          "when": "view == vardionixFindings",
          "group": "navigation@5"
        },
        {
          "command": "vardionix.installMcpIntegration",
          "when": "view == vardionixFindings",
          "group": "navigation@6"
        },
        {
          "command": "vardionix.listExcludedFindings",
          "when": "view == vardionixFindings",
          "group": "overflow@1"
        },
        {
          "command": "vardionix.showPolicy",
          "when": "view == vardionixFindings",
          "group": "overflow@2"
        },
        {
          "command": "vardionix.verifyMcpIntegration",
          "when": "view == vardionixFindings",
          "group": "overflow@3"
        }
      ],
      "view/item/context": [
        {
          "command": "vardionix.explainFinding",
          "when": "view == vardionixFindings && viewItem == finding",
          "group": "inline@1"
        },
        {
          "command": "vardionix.dismissFinding",
          "when": "view == vardionixFindings && viewItem == finding",
          "group": "inline@2"
        },
        {
          "command": "vardionix.rescanFindingFile",
          "when": "view == vardionixFindings && viewItem == finding",
          "group": "inline@3"
        },
        {
          "command": "vardionix.showPolicy",
          "when": "view == vardionixFindings && viewItem == finding",
          "group": "inline@4"
        }
      ]
    },
    "configuration": {
      "title": "Vardionix",
      "properties": {
        "vardionix.semgrepPath": {
          "type": "string",
          "default": "semgrep",
          "description": "Path to the Semgrep binary. Leave as 'semgrep' to auto-detect or auto-download.",
          "scope": "machine"
        },
        "vardionix.defaultRuleset": {
          "type": "string",
          "default": "auto",
          "description": "Default Semgrep ruleset to use for scans."
        },
        "vardionix.scanOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Legacy mode: scan every saved file, even when it has no current findings.",
          "scope": "resource"
        },
        "vardionix.rescanOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Re-scan files on save when they have active findings or pending verification entries.",
          "scope": "resource"
        },
        "vardionix.rescanOnIdle": {
          "type": "boolean",
          "default": true,
          "description": "Schedule a background file re-scan after you stop typing for a short period. This only runs when the document is already saved or auto-save keeps it clean.",
          "scope": "resource"
        },
        "vardionix.rescanDebounceMs": {
          "type": "number",
          "default": 1500,
          "minimum": 250,
          "description": "How long Vardionix waits after typing stops before attempting an idle re-scan.",
          "scope": "resource"
        },
        "vardionix.hideTouchedFindingsImmediately": {
          "type": "boolean",
          "default": true,
          "description": "Move touched findings into a pending verification state immediately after you edit the affected code.",
          "scope": "resource"
        },
        "vardionix.severityFilter": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "info"
            ]
          },
          "description": "Only show findings at these severity levels. Leave empty to show all."
        }
      }
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "vscode:prepublish": "node build.mjs",
    "package": "npx @vscode/vsce package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.0",
    "esbuild": "^0.25.4"
  },
  "dependencies": {
    "yauzl": "^3.3.0"
  }
}
