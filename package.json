{
  "name": "vardionix-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run typecheck && npm run build:workspaces",
    "build:workspaces": "npm run build --workspaces",
    "test": "vitest run",
    "test:vscode-host": "node scripts/run-vscode-extension-host-tests.mjs",
    "test:watch": "vitest",
    "typecheck": "tsc --build --force",
    "clean": "rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/sql.js": "^1.4.11",
    "@vscode/test-electron": "^2.5.2",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=22"
  }
}
